                "description": "End date for availability window check"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "Authorization",
              "value": "{{Authorization}}",
              "placement": "header"
            }
          },
          "docs": "Validates content availability for scheduling, sales, and publishing workflows. Checks rights windows for a given territory, platform, and time period."
        }
